# NEXT_PUBLIC_API_URL: The URL for the backend API (required).
# On Netlify/Vercel: set this BEFORE the build and trigger a new deploy so it gets inlined.
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# REVALIDATE_SECRET: Must match FRONTEND_REVALIDATE_SECRET on your Laravel/API backend exactly
# (same characters: 0 vs O, 1 vs l, etc.) so that /api/revalidate accepts webhook calls.
REVALIDATE_SECRET=your-secret-key

# News Backend API (Local Herd Environment)
NEXT_PUBLIC_NEWS_API_URL=http://berita-mone.test/api

# M-One CDN Proxy (Cloudflare Worker)
NEXT_PUBLIC_CDN_URL=https://cdn.mutudev.com
