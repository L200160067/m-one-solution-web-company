0:{"buildId":"3qsqp-5qAziFGG5hz9xl8","rsc":["$","$1","c",{"children":[["$","$L2",null,{"post":{"id":"mengenal-ui-ux-design","title":"Mengenal Perbedaan UI dan UX Design","excerpt":"UI dan UX seringkali dianggap sama, padahal keduanya memiliki peran yang berbeda dalam pengembangan produk digital.","content":"UI (User Interface) dan UX (User Experience) seringkali dianggap sama, padahal keduanya memiliki peran yang berbeda dalam pengembangan produk digital. UI berfokus pada tampilan visual, seperti warna, tipografi, dan tata letak elemen. Sementara itu, UX berfokus pada pengalaman pengguna secara keseluruhan, termasuk kemudahan penggunaan, efisiensi, dan kepuasan pengguna. Keduanya harus bekerja sama dengan baik untuk menciptakan produk digital yang sukses. Tim desain M-One Solution selalu memperhatikan aspek UI dan UX dalam setiap proyek yang kami kerjakan.","author":"Tim M-One","date":"02 Feb 2024","category":"Design","imageUrl":"https://raw.githubusercontent.com/m-one-solution/mone-assets/main/images/blog/blog5.webp"}}],[["$","script","script-0",{"src":"/_next/static/chunks/5eaf12c554f89782.js","async":true}]],["$","$L3",null,{"children":["$","$4",null,{"name":"Next.MetadataOutlet","children":"$@5"}]}]]}],"loading":null,"isPartial":false}
